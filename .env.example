# Copia este fichero a `.env` y rellena los valores reales.
# NUNCA subas el .env real al repositorio (está en .gitignore).

# --- Google Gemini (chat + function calling) ---
# Genera una key gratuita en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelo de chat (function calling). Flash = tier gratuito.
# Nota: gemini-2.0-flash agota cuota gratuita rápido; 2.5-flash va mejor.
GEMINI_CHAT_MODEL=gemini-2.5-flash

# --- Embeddings ---
# Por defecto LOCALES (sentence-transformers): coste cero, sin rate limit, offline.
# El tier gratuito de Gemini embeddings no permite embeddar las ~3.600 reglas
# (límite ~1.000/día); ver decisions.md §2.3. Cambia a "gemini" solo si tienes cuota.
EMBED_BACKEND=local
LOCAL_EMBED_MODEL=intfloat/multilingual-e5-base
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Vector store (Chroma persistente en disco) ---
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=mtg_rules

# Ruta del corpus a ingerir (.txt oficial o el .pdf del reglamento).
RULES_TXT_PATH=data/comprehensive_rules.txt

# --- API de cartas (Magic: The Gathering) ---
# No requiere clave para consultas básicas. Límite ~5.000 req/hora.
MTG_API_BASE=https://api.magicthegathering.io/v1
MTG_CACHE_DIR=data/cache

# --- RAG ---
RAG_TOP_K=10              # nº de chunks recuperados por consulta
RAG_MIN_SIMILARITY=0.6    # umbral de SIMILITUD coseno (mayor = más relevante); descarta sim < umbral

# --- Memoria de conversación ---
MEMORY_MAX_TURNS=6        # turnos previos que se conservan por sesión
